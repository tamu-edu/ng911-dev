<scenario name="ESRP_simple_call">
    <Global variables="IF_OSP_BCF, IF_BCF_ESRP, IF_CHFE_ESRP, IF_ESRP_CHFE, IF_TS-CHFE_ESRP,
                        conference_id, CHFE_tel, OSP_tel, TS-CHFE_tel,
                        SUBSCRIBE_CHFE_conference_Call_ID, REFER_CHFE_conference_Call_ID,
                        SUBSCRIBE_TS-CHFE_conference_Call_ID,
                        last_Via, last_From, last_To, last_Call-ID, last_CSeq"/>
    <recv request="INVITE">
        <operate
                method_name="rewrite_invite_for_esrp"
                src_ip="[$IF_BCF_ESRP]"
                dst_ip="[$IF_CHFE_ESRP]"
                dst_port="[local_port]"
        />
    </recv>
    <recv response="100" optional="true">
        <operate
                method_name="forward_message"
                src_ip="[$IF_CHFE_ESRP]"
                dst_ip="[$IF_BCF_ESRP]"
                dst_port="[local_port]"
        />
    </recv>
    <recv response="180" optional="true">
        <operate
                method_name="forward_message"
                src_ip="[$IF_CHFE_ESRP]"
                dst_ip="[$IF_BCF_ESRP]"
                dst_port="[local_port]"
        />
    </recv>
    <recv response="200">
        <operate
                method_name="forward_message"
                src_ip="[$IF_CHFE_ESRP]"
                dst_ip="[$IF_BCF_ESRP]"
                dst_port="[local_port]"
        />
    </recv>
    <recv request="ACK">
        <operate
                method_name="forward_message"
                src_ip="[$IF_BCF_ESRP]"
                dst_ip="[$IF_CHFE_ESRP]"
                dst_port="[local_port]"
        />
    </recv>
    <media
            type="rtp_proxy"
            proxy_ip="[local_ip]"
            proxy_port="5023"
            src_ip="[$IF_BCF_ESRP]"
            dst_ip="[$IF_CHFE_ESRP]"
            dst_port="5036"
    />
    <media
            type="rtp_proxy"
            proxy_ip="[local_ip]"
            proxy_port="5036"
            src_ip="[$IF_CHFE_ESRP]"
            dst_ip="[$IF_BCF_ESRP]"
            dst_port="5023"
    />
    <recv request="BYE">
        <operate
                method_name="forward_message"
                src_ip="[$IF_CHFE_ESRP]"
                dst_ip="[$IF_BCF_ESRP]"
                dst_port="[local_port]"
        />
    </recv>
    <recv response="200">
        <operate
                method_name="forward_message"
                src_ip="[$IF_BCF_ESRP]"
                dst_ip="[$IF_CHFE_ESRP]"
                dst_port="[local_port]"
        />
    </recv>
</scenario>
